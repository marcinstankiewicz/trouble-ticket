{
  "info": {
    "_postman_id": "troubleticket-api-collection",
    "name": "Trouble Ticket API",
    "description": "TMF621 Trouble Ticket API v1.0 Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "item": [
      {
        "name": "Trouble Tickets",
        "item": [
          {
            "name": "Create Trouble Ticket",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{jwt_token}}",
                  "type": "text"
                },
                {
                  "key": "Content-Type",
                  "value": "application/json",
                  "type": "text"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"externalId\": \"OK-123456\",\n  \"serviceId\": 987654321,\n  \"description\": \"Brak transmisji danych dla usługi klienta.\",\n  \"status\": \"new\",\n  \"note\": \"Zgłoszenie utworzone przez konto API partnera.\"\n}"
              },
              "url": {
                "raw": "{{baseUrl}}/api/v1/troubleTicket",
                "host": ["{{baseUrl}}"],
                "path": ["api", "v1", "troubleTicket"]
              }
            },
            "response": []
          },
          {
            "name": "List Trouble Tickets",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{jwt_token}}",
                  "type": "text"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/api/v1/troubleTicket",
                "host": ["{{baseUrl}}"],
                "path": ["api", "v1", "troubleTicket"]
              }
            },
            "response": []
          },
          {
            "name": "Get Trouble Ticket Details",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{jwt_token}}",
                  "type": "text"
                }
              ],
              "url": {
                "raw": "{{baseUrl}}/api/v1/troubleTicket/{{ticket_id}}",
                "host": ["{{baseUrl}}"],
                "path": ["api", "v1", "troubleTicket", "{{ticket_id}}"]
              }
            },
            "response": []
          },
          {
            "name": "Close Trouble Ticket",
            "request": {
              "method": "PATCH",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{jwt_token}}",
                  "type": "text"
                },
                {
                  "key": "Content-Type",
                  "value": "application/json",
                  "type": "text"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"status\": \"closed\"\n}"
              },
              "url": {
                "raw": "{{baseUrl}}/api/v1/troubleTicket/{{ticket_id}}",
                "host": ["{{baseUrl}}"],
                "path": ["api", "v1", "troubleTicket", "{{ticket_id}}"]
              }
            },
            "response": []
          }
        ]
      },
      {
        "name": "Notes",
        "item": [
          {
            "name": "Add Note to Trouble Ticket",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{jwt_token}}",
                  "type": "text"
                },
                {
                  "key": "Content-Type",
                  "value": "application/json",
                  "type": "text"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"text\": \"Klient prosi o potwierdzenie planowanego terminu zamknięcia.\"\n}"
              },
              "url": {
                "raw": "{{baseUrl}}/api/v1/troubleTicket/{{ticket_id}}/note",
                "host": ["{{baseUrl}}"],
                "path": ["api", "v1", "troubleTicket", "{{ticket_id}}", "note"]
              }
            },
            "response": []
          }
        ]
      }
    ],
    "variable": [
      {
        "key": "baseUrl",
        "value": "http://localhost:8080",
        "type": "string"
      },
      {
        "key": "jwt_token",
        "value": "",
        "type": "string",
        "description": "JWT Bearer Token - Generate via jwt.io with secret: 'your-super-secret-key-for-jwt-signing-do-not-use-in-production'"
      },
      {
        "key": "ticket_id",
        "value": "",
        "type": "string",
        "description": "Ticket ID received from create response"
      }
    ]
  }
}

